# Environment variables - DO NOT COMMIT
# Copy this file to .env.local and fill in your values

# ──────────────────────────────────────────
# Database (Neon Postgres)
# Get from: neon.tech or Vercel Storage dashboard
# ──────────────────────────────────────────
POSTGRES_URL=postgresql://user:****@host/dbname?sslmode=require

# ──────────────────────────────────────────
# Email (Resend)
# Get API key from: resend.com/api-keys
# For testing: use onboarding@resend.dev as FROM_EMAIL
# For production: verify your domain at resend.com/domains
# ──────────────────────────────────────────
RESEND_API_KEY=re_****
FROM_EMAIL=onboarding@resend.dev

# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Comma-separated list of authorized admin email addresses
ADMIN_EMAILS=your@email.com

# Secret key for signing JWT admin sessions
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=change-this-to-a-secure-random-string
